# Railway 部署环境变量配置示例
# Railway 会自动设置这些环境变量，无需手动配置

# ============================================
# Railway MySQL 服务自动提供的环境变量（无需手动设置）
# ============================================
# MYSQL_URL=mysql://root:password@host:3306/railway
# MYSQL_PUBLIC_URL=mysql://root:password@public-host:port/railway
# MYSQLHOST=railway.internal
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=your-password
# MYSQLPORT=3306
# MYSQL_ROOT_PASSWORD=your-password

# ============================================
# 可选：使用自定义数据库（如果不使用 Railway MySQL 服务）
# ============================================
# 方式 1: 使用 DATABASE_URL
# DATABASE_URL=mysql://username:password@host:port/database

# 方式 2: 单独配置
# DB_HOST=your-database-host
# DB_DATABASE=your-database-name
# DB_USERNAME=your-database-username
# DB_PASSWORD=your-database-password
# DB_PORT=3306

# ============================================
# PHP 运行时配置（Railway 自动设置）
# ============================================
# PORT=8080
